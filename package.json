{
  "name": "hacker-mission",
  "version": "0.0.1",
  "private": true,
  "description": "A Quasar Project",
  "keywords": [
    "quasar",
    "quasar-app",
    "quasar-app-vite",
    "quasar-cli",
    "vite",
    "vue",
    "vuejs"
  ],
  "author": "Karina.Pikul <Karina.Pikul@sva.de>",
  "type": "module",
  "scripts": {
    "lint": "oxfmt && oxlint --fix",
    "lint:check": "oxfmt --check && oxlint",
    "dev": "quasar dev",
    "postinstall": "quasar prepare --silent",
    "build": "quasar build -m spa",
    "deploy": "quasar build -m spa && gh-pages -d dist/spa"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.0",
    "quasar": "^2.21.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@quasar/app-vite": "^3.0.0-rc.6",
    "autoprefixer": "^10.4.27",
    "gh-pages": "^6.3.0",
    "oxfmt": "^0.x",
    "oxlint": "^1.x",
    "postcss": "^8.5.8"
  },
  "engines": {
    "node": ">= 26 || ^24 || ^22.12"
  },
  "productName": "Hacker Mission"
}
